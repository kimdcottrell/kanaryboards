{
  "allowScripts": {
    "allow": [
      "npm:esbuild",
      "npm:sharp",
      "npm:@anthropic-ai/claude-code",
      "npm:protobufjs"
    ],
    "deny": []
  },
  "lint": {
    "exclude": ["./dist/"]
  },
  "fmt": {
    "exclude": ["**/*.md", "**/*.mdx"]
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --allow-all astro dev",
    "build": "rm -rf ./.astro ./dist; deno run --allow-all astro build",
    "preview": "deno run --allow-all ./dist/server/entry.mjs",
    "astro": "deno run --allow-all astro",
    "pw": "PW_DISABLE_TS_ESM=true deno run --allow-all npm:@playwright/test/cli"
  }
}
