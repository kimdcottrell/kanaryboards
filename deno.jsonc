{
  "allowScripts": {
    "allow": [
      "npm:esbuild",
      "npm:sharp",
      "npm:@anthropic-ai/claude-code",
      "npm:protobufjs"
    ],
    "deny": []
  },
  "fmt": {
    "exclude": ["**/*.md", "**/*.mdx"]
  },
  "lint": {
    "exclude": ["./dist/"]
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --allow-all astro dev",
    "build": "rm -rf ./.astro ./dist; deno run --allow-all astro build",
    "preview": "deno run --allow-net --allow-read --allow-env ./dist/server/entry.mjs",
    "astro": "deno run --allow-all astro"
  },
  "imports": {
    // these are needed to get around Deno Deploy problems thanks to @deno/astro-adapter
    "@std/http": "jsr:@std/http@^1.1.0",
    "@std/path": "jsr:@std/path@^1.1.4"
    // NOTE: package.json MUST exist for:
    // - resolving preview error of `error: [ERR_UNSUPPORTED_ESM_URL_SCHEME] Only file and data URLs are supported by the default ESM loader. Received protocol 'astro'`
    // - dependabot does not support deno.jsonc
  }
}
