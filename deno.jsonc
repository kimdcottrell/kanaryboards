{
  "allowScripts": {
    "allow": [
      "npm:esbuild",
      "npm:sharp",
      "npm:@anthropic-ai/claude-code",
      "npm:protobufjs"
    ],
    "deny": []
  },
  "fmt": {
    "exclude": ["**/*.md", "**/*.mdx"]
  },
  "lint": {
    "exclude": ["./dist/"]
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --allow-all astro dev",
    "build": "rm -rf ./.astro ./dist; deno run --allow-all astro build",
    "preview": "deno run --allow-all ./dist/server/entry.mjs",
    "astro": "deno run --allow-all astro"
  },
  "imports": {
    "@std/http": "jsr:@std/http@^1.1.0" // this is needed to get around Deno Deploy problems thanks to @deno/astro-adapter
  }
}
