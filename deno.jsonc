{
  "allowScripts": {
    "allow": ["npm:esbuild@0.27.3", "npm:sharp@0.34.5"],
    "deny": []
  },
  "lint": {
    "exclude": ["./dist/"]
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --allow-all astro dev",
    "build": "deno run --allow-all astro build",
    "preview": "deno run --allow-all astro preview",
    "astro": "deno run --allow-all astro"
  }
}
