// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-docker-compose
{
  "name": "Kanary Boards Dev Container",
  // Update the 'dockerComposeFile' list if you have more compose files or use different names.
  // The .devcontainer/compose.yaml file contains any overrides you need/want to make.
  "dockerComposeFile": [
    "../compose.yaml"
  ],
  "containerEnv": {
    "DEVCONTAINER": "true"
  },
  // The 'service' property is the name of the service for the container that VS Code should
  // use. Update this value and .devcontainer/compose.yaml to the real service name.
  "service": "app",
  // The optional 'workspaceFolder' property is the path VS Code should open by default when
  // connected. This is typically a file mount in .devcontainer/compose.yaml
  "workspaceFolder": "/var/dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "bradlc.vscode-tailwindcss",
        "denoland.vscode-deno",
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers",
        "Anthropic.claude-code",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "claudeCode.preferredLocation": "panel",
        "claudeCode.disableLoginPrompt": true,
        // force javascript and typescript to use settings in deno.jsonc for formatting and linting
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "denoland.vscode-deno",
        "deno.enable": true,
        "deno.lint": true,
        "[typescriptreact]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[typescript]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[javascriptreact]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[javascript]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "css.customData": [
          ".vscode/tailwind.json"
        ],
        "[astro]": {
          "editor.defaultFormatter": "astro-build.astro-vscode"
        },
        "terminal.integrated.shell.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash (container default)": {
            "path": "/usr/bin/bash",
            "overrideName": true
          }
        }
      }
    }
  },
  // Uncomment the next line if you want to keep your containers running after VS Code shuts down.
  "shutdownAction": "none"
}
