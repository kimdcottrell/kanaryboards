// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-docker-compose
{
  "name": "Kanary Boards Dev Container",
  "dockerComposeFile": [
    "../compose.yaml"
  ],

  // NOTE ABOUT WHAT THESE COMMANDS DO:
  // - `initializeCommand`
  // - runs on local machine before the container starts
  // - (re)starts the ssh-agent at a fixed socket path (~/.ssh/agent.sock) and loads all ssh keys
  // - `postAttachCommand`
  // - fixes ownership of the mounted ssh-agent socket so the container user can access it
  "postAttachCommand": {
    // "gitsshkey": "HOST_GITSSHKEY=$(cat ${containerWorkspaceFolder}/.devcontainer/gitsshkey); cp /var/host_ssh/${HOST_GITSSHKEY##*/} /home/deno/.ssh/${HOST_GITSSHKEY##*/}; cp /var/host_ssh/${HOST_GITSSHKEY##*/}.pub /home/deno/.ssh/${HOST_GITSSHKEY##*/}.pub",
    "bashrc": "[ ! -f ${containerWorkspaceFolder}/.devcontainer/home/.bashrc ] || [ ! -s ${containerWorkspaceFolder}/.devcontainer/home/.bashrc ] && ( cp ${containerWorkspaceFolder}/.devcontainer/home/.sample_bashrc ${containerWorkspaceFolder}/.devcontainer/home/.bashrc ); echo 'source ${containerWorkspaceFolder}/.devcontainer/home/.bashrc' > /home/deno/.bashrc;",
    "zshrc": "[ ! -f ${containerWorkspaceFolder}/.devcontainer/home/.zshrc ] || [ ! -s ${containerWorkspaceFolder}/.devcontainer/home/.zshrc ] && ( cp ${containerWorkspaceFolder}/.devcontainer/home/.sample_zshrc ${containerWorkspaceFolder}/.devcontainer/home/.zshrc ); echo 'source ${containerWorkspaceFolder}/.devcontainer/home/.zshrc' > /home/deno/.zshrc;",
    "fix-ssh-sock": "sudo chown deno:deno /ssh-agent"
  },
  "remoteEnv": {
    "DEVCONTAINER": "true",
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  // this gets around a weird bug where running `claude` in the terminal of the
  // container doesn't work despite the OAuth token being set in the env vars
  // NOTE: https://github.com/anthropics/claude-code/issues/8938#issuecomment-3443723851
  "service": "app",
  "workspaceFolder": "/var/dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "bradlc.vscode-tailwindcss",
        "denoland.vscode-deno",
        "ms-azuretools.vscode-docker",
        "Anthropic.claude-code",
        "streetsidesoftware.code-spell-checker",
        "ms-vscode-remote.remote-containers"
      ],
      "settings": {
        "claudeCode.preferredLocation": "panel",
        "claudeCode.disableLoginPrompt": true,
        "cSpell.configPaths": [
          "${containerWorkspaceFolder}/.devcontainer/cspell.json"
        ],
        // force javascript and typescript to use settings in deno.jsonc for formatting and linting
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "denoland.vscode-deno",
        "deno.enable": true,
        "deno.lint": true,
        "[typescriptreact]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[typescript]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[javascriptreact]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[javascript]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "css.customData": [
          "${containerWorkspaceFolder}/.devcontainer/tailwind.json"
        ],
        "[markdown]": {
          "editor.defaultFormatter": "vscode.markdown-language-features"
        },
        "[astro]": {
          "editor.defaultFormatter": "astro-build.astro-vscode"
        },
        "terminal.integrated.shell.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/usr/bin/bash",
            "overrideName": true
          }
        }
      }
    }
  },
  "shutdownAction": "none",
  "mounts": [
    "source=${localEnv:HOME}/.ssh/agent.sock,target=/ssh-agent,type=bind"
  ]

}
