// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-docker-compose
{
  "name": "Kanary Boards Dev Container",
  "dockerComposeFile": [
    "../compose.yaml"
  ],
  "containerEnv": {
    "DEVCONTAINER": "true"
  },
  // this gets around a weird bug where running `claude` in the terminal of the container doesn't work
  // despite the OAuth token being set in the env vars
  // NOTE: https://github.com/anthropics/claude-code/issues/8938#issuecomment-3443723851
  "updateContentCommand": "cat <<< $(jq 'if has(\"hasCompletedOnboarding\") then . else . + {\"hasCompletedOnboarding\": true} end' ~/.claude.json) > ~/.claude.json",
  "service": "app",
  "workspaceFolder": "/var/dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "bradlc.vscode-tailwindcss",
        "denoland.vscode-deno",
        "ms-azuretools.vscode-docker",
        "Anthropic.claude-code",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "claudeCode.preferredLocation": "panel",
        "claudeCode.disableLoginPrompt": true,
        // force javascript and typescript to use settings in deno.jsonc for formatting and linting
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "denoland.vscode-deno",
        "deno.enable": true,
        "deno.lint": true,
        "[typescriptreact]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[typescript]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[javascriptreact]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[javascript]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "css.customData": [
          ".vscode/tailwind.json"
        ],
        "[astro]": {
          "editor.defaultFormatter": "astro-build.astro-vscode"
        },
        "terminal.integrated.shell.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash (container default)": {
            "path": "/usr/bin/bash",
            "overrideName": true
          }
        }
      }
    }
  },
  // Uncomment the next line if you want to keep your containers running after VS Code shuts down.
  "shutdownAction": "none"
}
