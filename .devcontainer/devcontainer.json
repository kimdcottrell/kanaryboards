// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-docker-compose
{
  "name": "Kanary Boards Dev Container",
  "dockerComposeFile": [
    "../compose.yaml"
  ],
  // this should allow you to push to git AS LONG AS your local machine can
  "mounts": [
    "source=${localEnv:HOME}/.ssh/agent.sock,target=/ssh-agent.sock,type=bind"
  ],
  "initializeCommand": "ssh-agent -a ~/.ssh/agent.sock || true",
  "remoteEnv": {
    "DEVCONTAINER": "true",
    "SSH_AUTH_SOCK": "/ssh-agent.sock"
  },
  // this gets around a weird bug where running `claude` in the terminal of the
  // container doesn't work despite the OAuth token being set in the env vars
  // NOTE: https://github.com/anthropics/claude-code/issues/8938#issuecomment-3443723851
  "service": "app",
  "workspaceFolder": "/var/dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "bradlc.vscode-tailwindcss",
        "denoland.vscode-deno",
        "ms-azuretools.vscode-docker",
        "Anthropic.claude-code",
        "streetsidesoftware.code-spell-checker",
        "ms-vscode-remote.remote-containers"
      ],
      "settings": {
        "claudeCode.preferredLocation": "panel",
        "claudeCode.disableLoginPrompt": true,
        "cSpell.configPaths": [
          "${containerWorkspaceFolder}/.devcontainer/cspell.json"
        ],
        // force javascript and typescript to use settings in deno.jsonc for formatting and linting
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "denoland.vscode-deno",
        "deno.enable": true,
        "deno.lint": true,
        "[typescriptreact]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[typescript]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[javascriptreact]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[javascript]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "css.customData": [
          "${containerWorkspaceFolder}/.devcontainer/tailwind.json"
        ],
        "[markdown]": {
          "editor.defaultFormatter": "vscode.markdown-language-features"
        },
        "[astro]": {
          "editor.defaultFormatter": "astro-build.astro-vscode"
        },
        "terminal.integrated.shell.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/usr/bin/bash",
            "overrideName": true
          }
        }
      }
    }
  },
  // Uncomment the next line if you want to keep your containers running after VS Code shuts down.
  "shutdownAction": "none"
}
