---
import HtmlHead from "./partials/HtmlHead.astro";

import Header from "./partials/Header.astro";
import DrawerMenu from "./partials/DrawerMenu.astro";

import Footer from "./partials/Footer.astro";
import CookieBanner from "@components/CookieBanner.astro";
import ClerkSignUpTrigger from "@components/ClerkSignUpTrigger.astro";
import type { Props as AstroSEOProps } from "astro-seo";
import type { Thing, WithContext } from "schema-dts";

interface Props {
  seo?: AstroSEOProps;
  schema?: WithContext<Thing>[];
}

const { seo, schema } = Astro.props;
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);

const pageClasses =
  pathSegments.length === 0
    ? ["page-home"]
    : pathSegments.map((_, index) => {
        const segmentsSoFar = pathSegments.slice(0, index + 1);
        return `page-${segmentsSoFar.join("-")}`;
      });
---

<html lang="en">
  <head>
    <HtmlHead seo={seo} schema={schema} />
  </head>
  <body class:list={["drawer", ...pageClasses]}>
    <input id="drawer-menu" type="checkbox" class="drawer-toggle" />
    <DrawerMenu server:defer>
      <div
        slot="fallback"
        class="drawer-side z-99 is-drawer-close:overflow-visible"
      >
        <label
          for="drawer-menu"
          aria-label="close sidebar"
          class="drawer-overlay"></label>
        <div
          class="flex min-h-full flex-col items-start bg-base-200 is-drawer-close:w-14 is-drawer-open:w-64"
        >
          <ul class="menu w-full grow">
            <li>
              <span class="loading loading-dots loading-xl"></span>
            </li>
          </ul>
        </div>
      </div>
    </DrawerMenu>
    <main class="drawer-content">
      <Header />
      <slot />
      <Footer />
    </main>
    <CookieBanner />
    <ClerkSignUpTrigger />
  </body>
</html>
