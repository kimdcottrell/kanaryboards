---
import HtmlHead from "./partials/HtmlHead.astro";

import Header from "./partials/Header.astro";
import DrawerMenu from "./partials/DrawerMenu.astro";

import Footer from "./partials/Footer.astro";
import CookieBanner from "@components/CookieBanner.astro";
import ClerkSignUpTrigger from "@components/ClerkSignUpTrigger.astro";
import type { SeoMetadata } from "@lib/seo-schema.ts";

interface Props {
  seo?: SeoMetadata;
}

const { seo } = Astro.props;
const pageClass = `page-${Astro.url.pathname === "/" ? "home" : Astro.url.pathname.replace(/^\/|\/$/g, "").replace(/\//g, "-")}`;
---

<html lang="en">
  <head>
    <HtmlHead seo={seo} />
  </head>
  <body class:list={["drawer", pageClass]}>
    <input id="drawer-menu" type="checkbox" class="drawer-toggle" />
    <DrawerMenu server:defer>
      <div
        slot="fallback"
        class="drawer-side z-99 is-drawer-close:overflow-visible"
      >
        <label
          for="drawer-menu"
          aria-label="close sidebar"
          class="drawer-overlay"
        ></label>
        <div
          class="flex min-h-full flex-col items-start bg-base-200 is-drawer-close:w-14 is-drawer-open:w-64"
        >
          <ul class="menu w-full grow">
            <li>
              <span class="loading loading-dots loading-xl"></span>
            </li>
          </ul>
        </div>
      </div>
    </DrawerMenu>
    <main class="drawer-content">
      <Header />
      <slot />
      <Footer />
    </main>
    <CookieBanner />
    <ClerkSignUpTrigger />
  </body>
</html>
