---
import { Show, UserButton, SignInButton } from "@clerk/astro/components";

import ThemeProvider from "@components/theme/ThemeProvider";
import ThemeToggle from "@components/theme/ThemeToggle";
---

<nav class="navbar grid bg-base-200 shadow-sm z-25">
    <div class="w-11/12 mx-auto flex items-center justify-between">
        <div class="flex-none">
            <label
                for="drawer-menu"
                class="btn btn-square btn-ghost drawer-button"
            >
                <span class="iconify hugeicons--menu-01 text-xl"></span>
            </label>
        </div>
        <div class="flex-1">
            <a href="/" class="flex items-center text-xl font-bold">
                <span
                    class="iconify mingcute--bird-fill text-5xl text-(--color-row-yellow)"
                ></span>
                <h1
                    class="text-3xl leading-15 font-normal font-logo bg-clip-text text-transparent bg-linear-to-r from-accent to-secondary"
                >
                    Kanby
                </h1>
            </a>
        </div>
        <div class="flex-none">
            <div id="login-controls" class="flex items-center gap-4">
                <ThemeProvider>
                    <ThemeToggle client:only="react" />
                </ThemeProvider>
                <Show when="signed-out">
                    <SignInButton asChild mode="modal">
                        <button class="btn btn-warning">
                            <span class="iconify basil--login-solid text-xl"
                            ></span>
                            Sign In
                        </button>
                    </SignInButton>
                </Show>
                <Show when="signed-in">
                    <UserButton />
                </Show>
            </div>
        </div>
    </div>
</nav>
