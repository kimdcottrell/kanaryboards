---
import { getBoard } from "@lib/kv.ts";
import { byOrder } from "@components/context/ordering.ts";

const { userId } = Astro.locals.auth();
const isAuthenticated = !!userId;
const boardId = Astro.locals.boardId;

let rows: { id: string; title: string }[] = [];
if (isAuthenticated && boardId) {
    const board = await getBoard(boardId);
    rows = [...(board?.rows ?? [])]
        .sort(byOrder)
        .map((r) => ({ id: r.id, title: r.title }));
}
---

<div class="drawer-side z-99 is-drawer-close:overflow-visible">
    <label for="drawer-menu" aria-label="close sidebar" class="drawer-overlay"
    ></label>
    <div
        class="flex min-h-full flex-col items-start bg-base-200 is-drawer-close:w-14 is-drawer-open:w-64"
    >
        <!-- Sidebar content here -->
        <ul class="menu w-full grow">
            <li>
                <a href="/">
                    <button
                        class="is-drawer-close:tooltip is-drawer-close:tooltip-right"
                        data-tip="Homepage"
                    >
                        <!-- Home icon -->
                        <span class="iconify hugeicons--home-03 text-xl"></span>
                        <span class="is-drawer-close:hidden">Homepage</span>
                    </button>
                </a>
            </li>
            <li>
                <a href="/dashboard">
                    <button
                        class="is-drawer-close:tooltip is-drawer-close:tooltip-right"
                        data-tip="Dashboard"
                    >
                        <!-- Settings icon -->
                        <span
                            class="iconify hugeicons--left-to-right-list-dash text-xl"
                        ></span>
                        <span class="is-drawer-close:hidden">Dashboard</span>
                    </button>
                </a>
                <ul
                    id="drawer-row-list"
                    data-authenticated={String(isAuthenticated)}
                >
                    {
                        rows.map((row) => (
                            <li>
                                <a
                                    href={`/dashboard/row/${row.id}`}
                                    data-board-link
                                >
                                    {row.title}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </li>
            <li>
                <a href="/blog">
                    <button
                        class="is-drawer-close:tooltip is-drawer-close:tooltip-right"
                        data-tip="Blog"
                    >
                        <!-- Settings icon -->
                        <span class="iconify hugeicons--rss text-xl"></span>
                        <span class="is-drawer-close:hidden">Blog</span>
                    </button>
                </a>
            </li>
        </ul>
    </div>
</div>

<script>
    import { byOrder } from "@components/context/ordering.ts";
    const list = document.getElementById("drawer-row-list");
    if (list && list.dataset.authenticated !== "true") {
        try {
            const board = JSON.parse(
                localStorage.getItem("kanby-v0-1-0") ?? "null",
            );
            for (const row of [...(board?.rows ?? [])].sort(byOrder)) {
                const li = document.createElement("li");
                const a = document.createElement("a");
                a.href = `/dashboard/row/${row.id}`;
                a.dataset.boardLink = "";
                a.textContent = row.title;
                li.appendChild(a);
                list.appendChild(li);
            }
        } catch {
            /* no/invalid local board */
        }
    }
</script>
