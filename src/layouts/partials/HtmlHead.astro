---
import "@styles/global.css";
import "@lyfie/luthor/styles.css";

import { Font } from "astro:assets";

import GoogleAnalytics from "@components/seo/partials/GoogleAnalytics.astro";
import SEO from "@components/seo/SEO.astro";
import { CONSENT_COOKIE, hasAnalyticsConsent } from "@lib/consent";
import type { SeoMetadata } from "@src/content.config";

interface Props {
    seo?: SeoMetadata;
}

const { seo } = Astro.props;
const googleTag = import.meta.env.GOOGLE_TAG;
const analyticsConsent = hasAnalyticsConsent(
    Astro.cookies.get(CONSENT_COOKIE)?.value,
);
---

<meta charset="UTF-8" />
<meta
    name="viewport"
    content="viewport-fit=cover, width=device-width, initial-scale=1.0"
/>
<Font cssVariable="--font-cherry-bomb-one" />
<Font cssVariable="--font-roboto-slab" />
<Font cssVariable="--font-nunito" />
<Font cssVariable="--font-inter" />
<SEO seo={seo} />
{
    googleTag && (
        <GoogleAnalytics tag={googleTag} analyticsConsent={analyticsConsent} />
    )
}

<link rel="icon" type="image/x-icon" href="/favicon.ico" />
