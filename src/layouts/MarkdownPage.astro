---
import BaseLayout from "@layouts/BaseLayout.astro";
import Prose from "@components/pages/Prose.astro";
import { setPublicCache } from "@lib/http/cache-headers";
import type { Props as AstroSEOProps } from "astro-seo";

interface Props {
  frontmatter: {
    title: string;
    description: string;
  };
}

const { frontmatter } = Astro.props;

setPublicCache(Astro);

const seo: AstroSEOProps = {
  title: frontmatter.title,
  description: frontmatter.description,
};
---

<BaseLayout seo={seo}>
  <Prose>
    <slot />
  </Prose>
</BaseLayout>
