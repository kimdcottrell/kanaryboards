---
import TestingIsland from "@components/TestingIsland.astro";
export const prerender = true;

const import_secret = import.meta.env.TESTING;
const deno_secret = Deno.env.get("TESTING");
---

<h1>Build</h1>

<p>import.meta.env: {import_secret}</p>

<p>Deno.env.get: {deno_secret}</p>

<TestingIsland server:defer />
