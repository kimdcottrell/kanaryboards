---
import Layout from "@layouts/BaseLayout.astro";
import Prose from "@components/pages/Prose.astro";
import { PrivacyPolicy } from "@policystack/react/policy";
import config from "@src/policystack";

const seo = {
    title: "Privacy Policy",
    description: "How Kanby collects, uses, and protects your data.",
};
---

<Layout seo={seo}>
    <Prose>
        <h1>Privacy Policy</h1>
        <PrivacyPolicy client:load config={config} />
    </Prose>
</Layout>
