---
import KanbanBoard from "../components/KanbanBoard.jsx";
import "../styles/global.css";
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kanary Boards</title>
  </head>
  <body class="bg-slate-100 text-slate-900">
    <nav class="navbar bg-base-100 shadow-sm">
        <a class="text-xl font-bold">A semi-vibecoded (guidecoded?) Kanban Board project by Kim D. Cottrell</a>
    </nav>
    <main class="min-h-screen sm:p-10">
      <section class="mx-auto w-full max-w-max rounded-[2rem] border border-slate-200 bg-white p-8 shadow-xl shadow-slate-400/10">
        <header class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.3em] text-cyan-600/90">Organize your workflow</p>
            <h1 class="mt-3 text-4xl font-semibold text-slate-950 sm:text-5xl">Kanary Boards</h1>
          </div>
          <p class="max-w-2xl text-slate-600">
            Define rows and columns, then add tasks with titles, descriptions, and optional checklists.
          </p>
        </header>
        <KanbanBoard client:load />
      </section>
    </main>
    <footer class="mt-10 py-6 text-center text-sm text-slate-600">
    Made with Claude and <a href="https://kimdcottrell.com" class="text-cyan-600 hover:underline">Kim D. Cottrell</a>
    </footer>
  </body>
</html>
