---
import KanbanBoard from "../components/KanbanBoard.jsx";
import "../styles/global.css";
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kanary Boards</title>
  </head>
  <body class="bg-slate-100 text-slate-900">
    <nav class="navbar bg-base-100 shadow-sm">
        <a class="text-xl font-bold">An AI-showcase Kanban Board project by Kim D. Cottrell</a>
    </nav>
    <main class="min-h-screen sm:p-10">
      <section class="mx-auto w-full max-w-max rounded-[2rem] border border-slate-200 bg-white p-8 shadow-xl shadow-slate-400/10">
        <header class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.3em] text-cyan-600/90">Organize your workflow</p>
            <h1 class="mt-3 text-4xl font-semibold text-slate-950 sm:text-5xl">Kanary Boards</h1>
          </div>
          <p class="max-w-2xl text-slate-600">
            A really basic kanban board project built with Deno, Astro, and Tailwind CSS. <br />
            Create rows and tasks, drag and drop them around as needed.<br />
            Generate tasks using AI by entering a prompt describing the type of tasks you want to create, and the AI will return a list of tasks matching your description.<br />
            Data is only persisted in local browser storage... <em><small>For now.</small></em>
          </p>
        </header>
        <KanbanBoard client:load />
      </section>
    </main>
    <footer class="mt-10 py-6 text-center text-sm text-slate-600">
        <p>Made with Claude and <a href="https://kimdcottrell.com" class="text-cyan-600 hover:underline">Kim D. Cottrell</a>.</p>
        <p>Powered by Deno (a JavaScript runtime and Node.js alternative), Astro, and Tailwind CSS.</p>
    </footer>
  </body>
</html>
