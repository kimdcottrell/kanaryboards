---
import KanbanBoard from "../components/KanbanBoard.jsx";
import "../styles/global.css";
---
<html lang="en" data-theme="dracula">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kanary Boards</title>
  </head>
  <body>
    <nav class="navbar md:px-20 sm:px-10 bg-base-300 shadow-sm">
        <a class="text-xl font-bold">An AI-native Kanban Board project by Kim D. Cottrell</a>
    </nav>
    <main class="min-h-screen">
      <section class="mx-auto w-full">
        <KanbanBoard client:load />
      </section>
    </main>
    <footer class="mt-10 py-6 text-center text-sm">
        <p>Made with Claude and <a href="https://kimdcottrell.com" class="hover:underline">Kim D. Cottrell</a>.</p>
        <p>Powered by Deno (a JavaScript runtime and Node.js alternative), Astro, and Tailwind CSS.</p>
        <p>AI-powered content generation achieved through the SciTely API and the Deepseek v3.2 model.</p>
    </footer>
  </body>
</html>
