---
import { render } from "astro:content";
import BlogPostLayout from "@layouts/BlogPostLayout.astro";
import Prose from "@components/pages/Prose.astro";
import { getProtectedCollection } from "@src/utils";
import { setPublicCache } from "@lib/http/cache-headers";

setPublicCache(Astro, "x-playwright-test");

const { slug } = Astro.params;

const isPlaywrightTest =
  Astro.request.headers.get("x-playwright-test") === "true";
const posts = await getProtectedCollection("blog", {
  includeTestOnly: isPlaywrightTest,
});
const entry = posts.find((post) => post.id === slug);

const { Content } = entry ? await render(entry) : { Content: null };
---

<BlogPostLayout entry={entry}>
  {
    Content && (
      <Prose>
        <Content />
      </Prose>
    )
  }
</BlogPostLayout>
