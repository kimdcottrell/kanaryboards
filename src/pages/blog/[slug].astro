---
import { getEntry, render } from "astro:content";
import Layout from "@layouts/BaseLayout.astro";
import { getProtectedCollection } from "@src/utils";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getProtectedCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { slug } = Astro.params;

const entry = await getEntry("blog", slug);

if (!entry) {
  Astro.response.status = 404;
  Astro.response.statusText = "This article does not exist.";
}

const { Content } = entry ? await render(entry) : { Content: null };
---

<Layout seo={entry?.data}>
  {Content && (
    <div class="prose">
      <Content />
    </div>
  )}
</Layout>
