---
import Layout from "@layouts/BaseLayout.astro";
import Archive from "@components/pages/blog/Archive.astro";
import { getProtectedCollection } from "@src/utils";
import { setPublicCache } from "@lib/http/cache-headers";

setPublicCache(Astro, "x-playwright-test");

const { tag } = Astro.params;

const isPlaywrightTest =
    Astro.request.headers.get("x-playwright-test") === "true";
const allPosts = await getProtectedCollection("blog", {
    includeTestOnly: isPlaywrightTest,
});

const posts = allPosts.filter((post) => post.data.tags?.includes(tag!));

const allTags = [
    ...new Set(allPosts.flatMap((post) => post.data.tags ?? [])),
].sort();

let seo = {
    title: `Blog — #${tag}`,
    description: `Blog posts tagged ${tag}.`,
};
---

<Layout seo={seo}>
    <Archive
        posts={posts}
        allTags={allTags}
        activeTag={tag}
        emptyMessage={`No blog posts tagged “${tag}”.`}
    />
</Layout>
