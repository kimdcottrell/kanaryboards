---
import { AstroError } from "astro/errors";
const { tag } = Astro.props;
if (!tag)
    throw new AstroError(
        "GoogleTag is missing. This will cause analytics to not load.",
        "Check to see if the GOOGLE_TAG environment variable is set and being passed correctly to the component.",
    );
const url = `https://www.googletagmanager.com/gtag/js?id=${tag}`;
const htmlString = `
<script>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
        dataLayer.push(arguments);
    }
    gtag("js", new Date());
    gtag("config", "${tag}");
</script>
`;
---

<script is:inline src={url}></script>
<Fragment set:html={htmlString} />
