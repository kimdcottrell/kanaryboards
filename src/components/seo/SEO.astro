---
import BasicTags from "./partials/Basic.astro";
import ArticleTags from "./partials/Article.astro";
import type { SeoMetadata } from "@src/content.config";

export interface Props {
  seo?: SeoMetadata;
}

const { seo } = Astro.props;
---

{
  seo && (
    <>
      <BasicTags {...seo} />
      {seo.metadata?.article && <ArticleTags {...seo} />}
    </>
  )
}
