---
import { CONSENT_COOKIE } from "@lib/consent.ts";
import { categories } from "@lib/cookie-categories.ts";

// Render the banner hidden for returning visitors so it never flashes: the
// cookie is server-readable, and the client store reconciles on hydrate.
const hasConsent = Boolean(Astro.cookies.get(CONSENT_COOKIE)?.value);
---

<div
    data-policystack-banner
    role="region"
    aria-label="Cookie consent"
    hidden={hasConsent}
    class="fixed inset-x-0 bottom-0 z-40 border-t border-base-300 bg-base-100 shadow-lg"
>
    <div
        class="mx-auto flex max-w-4xl flex-col gap-3 px-4 py-4 sm:flex-row sm:items-center sm:justify-between"
    >
        <p class="text-sm text-base-content">
            We use cookies to run this site and, with your OK, to understand how
            it's used. Choose what you'd like to allow.
        </p>
        <div class="flex flex-wrap gap-2">
            <button type="button" data-action="customize" class="btn btn-ghost btn-sm">
                Customize
            </button>
            <button type="button" data-action="necessary" class="btn btn-ghost btn-sm">
                Necessary only
            </button>
            <button type="button" data-action="all" class="btn btn-primary btn-sm">
                Accept all
            </button>
        </div>
    </div>
</div>

<div
    data-policystack-prefs
    class="modal"
    role="dialog"
    aria-modal="true"
    aria-label="Cookie preferences"
>
    <div class="modal-box">
        <h3 class="text-lg font-semibold">Cookie preferences</h3>
        <p class="mt-1 text-sm text-base-content/70">
            Essential cookies are always on. Turn the rest on or off, then save.
        </p>
        <div class="mt-4 flex flex-col gap-3">
            {
                categories.map((c) => (
                    <label class="flex items-start justify-between gap-4 rounded-md border border-base-300 px-4 py-3">
                        <span class="flex flex-col">
                            <span class="text-sm font-medium">{c.label}</span>
                            {c.description && (
                                <span class="text-xs text-base-content/60">
                                    {c.description}
                                </span>
                            )}
                        </span>
                        <input
                            type="checkbox"
                            class="checkbox checkbox-sm mt-1"
                            data-category={c.key}
                            checked={c.locked === true}
                            disabled={c.locked}
                        />
                    </label>
                ))
            }
        </div>
        <div class="modal-action">
            <button type="button" data-action="cancel" class="btn btn-ghost btn-sm">
                Cancel
            </button>
            <button type="button" data-action="save" class="btn btn-primary btn-sm">
                Save preferences
            </button>
        </div>
    </div>
    <button
        type="button"
        data-action="cancel"
        class="modal-backdrop"
        aria-label="Close cookie preferences">close</button
    >
</div>

<script>
    import { createConsentStore } from "@policystack/core/consent";
    import { cookieAdapter } from "@policystack/core/consent/storage/cookie";
    import { categories } from "../lib/cookie-categories.ts";
    import { CONSENT_COOKIE } from "../lib/consent.ts";

    const store = createConsentStore({
        categories,
        canWithdraw: true,
        // No jurisdictionResolver → conservative opt-in everywhere: the banner
        // shows for every new visitor and analytics stays off until accepted.
        adapter: cookieAdapter({
            name: CONSENT_COOKIE,
            // A Secure cookie is dropped over http://localhost (dev + Playwright),
            // so only set Secure when actually served over https.
            secure: window.location.protocol === "https:",
            maxAge: 60 * 60 * 24 * 365,
        }),
    });

    const banner = document.querySelector(
        "[data-policystack-banner]",
    ) as HTMLElement;
    const prefs = document.querySelector(
        "[data-policystack-prefs]",
    ) as HTMLElement;
    const checkboxes = prefs.querySelectorAll<HTMLInputElement>(
        "input[data-category]",
    );

    type State = ReturnType<typeof store.getState>;

    // Bridge PolicyStack decisions into Google Consent Mode v2. gtag is absent
    // under Playwright / when GOOGLE_TAG is unset, so guard the call.
    function syncConsentMode(state: State) {
        const gtag = (window as unknown as { gtag?: (...a: unknown[]) => void })
            .gtag;
        if (typeof gtag !== "function") return;
        gtag("consent", "update", {
            analytics_storage: state.decisions.analytics ? "granted" : "denied",
        });
    }

    function render(state: State) {
        banner.hidden = state.route !== "cookie";
        prefs.classList.toggle("modal-open", state.route === "preferences");
        for (const cb of checkboxes) {
            const key = cb.dataset.category;
            if (key) cb.checked = state.decisions[key] ?? false;
        }
        syncConsentMode(state);
    }

    store.subscribe(render);
    render(store.getState());

    banner
        .querySelector('[data-action="customize"]')!
        .addEventListener("click", () => store.setRoute("preferences"));
    banner
        .querySelector('[data-action="necessary"]')!
        .addEventListener("click", () => store.acceptNecessary());
    banner
        .querySelector('[data-action="all"]')!
        .addEventListener("click", () => store.acceptAll());

    for (const cb of checkboxes) {
        cb.addEventListener("change", () => {
            const key = cb.dataset.category;
            if (key) store.toggle(key);
        });
    }

    for (const el of prefs.querySelectorAll('[data-action="cancel"]')) {
        el.addEventListener("click", () => store.setRoute("cookie"));
    }
    prefs
        .querySelector('[data-action="save"]')!
        .addEventListener("click", () => store.save());

    // Footer "Cookie settings" (and any other trigger) reopens the banner.
    window.addEventListener("policystack:open", () =>
        store.setRoute("cookie"),
    );
</script>
