{
  "enabledMcpjsonServers": [
    "Astro docs",
    "Daisy UI docs",
    "Deno docs",
    "Docker docs",
    "Google GenAI docs",
    "Luthor docs",
    "Zod docs",
    "React docs",
    "Preact docs",
    "Tailwind docs"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session_start/installRequiredPlugins.sh",
            "statusMessage": "Checking plugins..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session_start/fixDevcontainerClaudeExecutable.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": false,
    "playwright@claude-plugins-official": true
  },
  "autoMemoryDirectory": "$CLAUDE_PROJECT_DIR/.claude/memory",
  "autoMemoryEnabled": true
}
