# REQUIRED: Your local user ID — run `id -u`
LOCAL_MACHINE_UID=1000

# REQUIRED: Your local group ID — run `id -g` 
LOCAL_MACHINE_GID=1000

# REQUIRED:Google AI Studio API key (used for board autocomplete)
GOOGLE_AI_STUDIO_KEY='' 

# REQUIRED: OAuth token for Claude Code inside the container .
# generated on local machine.
# run: claude setup-token 
# this bypasses the login prompt in CC's extension for VSCode.
# if bugged, on your local machine, run: `rm -rf ~/.claude ~/.claude.json` and then `claude setup-token` again.
CLAUDE_CODE_OAUTH_TOKEN='' 

# REQUIRED: These are used for end-to-end testing with Clerk. You can create a test user in your Clerk dashboard and use those credentials here.
E2E_CLERK_USER_EMAIL=""
E2E_CLERK_USER_PASSWORD=""

# OPTIONAL: Google Analytics tag ID 
GOOGLE_TAG='G-xxxxxxx'

