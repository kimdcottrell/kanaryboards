{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "./node_modules/astro/client.d.ts",
    "src/content.config.js",
    "**/*"
  ],
  "exclude": [
    "dist",
    "playwright-report",
    "test-results"
  ],
  "types": ["vitest/globals", "deno"],
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowImportingTsExtensions": true,
    "paths": {
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@lib/*": ["./src/lib/*"],
      "@pages/*": ["./src/pages/*"],
      "@src/*": ["./src/*"],
      "@styles/*": ["./src/styles/*"]
    }
  }
}
