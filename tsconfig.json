{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "src/content.config.js",
    "**/*",
  ],
  "exclude": [
    "dist",
    "tests/playwright",
    "playwright.config.ts",
    "playwright-report",
    "test-results"
  ],
  "types": ["vitest/globals"],
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@pages/*": ["./src/pages/*"],
      "@components/*": ["./src/components/*"]
    }
  }
}
